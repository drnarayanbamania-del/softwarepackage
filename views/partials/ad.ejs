<%
  var a = ads[slot];
  var active = ads.enabled && a && a.enabled &&
    ((a.pages && a.pages.includes(page)) || a.page === page);
%>
<% if (active) { %>
<div class="ad-placement" style="margin: 16px 0; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 250px;">
  <span class="ad-lbl" style="font-size: .64rem; font-weight: 700; text-transform: uppercase; color: var(--ad-label, #a09030); letter-spacing: .08em; margin-bottom: 8px; display: block;">Advertisement</span>
  <script async="async" data-cfasync="false" src="https://pl30315640.effectivecpmnetwork.com/<%= a.zoneId %>/invoke.js"></script>
  <div id="container-<%= a.zoneId %>"></div>
</div>
<% } %>
